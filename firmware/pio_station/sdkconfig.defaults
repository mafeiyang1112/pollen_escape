CONFIG_ESP_MAXIMUM_RETRY=10
CONFIG_SENSOR_POST_URL="http://10.104.85.85:5000/data"
CONFIG_SENSOR_DEVICE_ID="esp32-s3-real-001"
CONFIG_SENSOR_AO_GPIO=14
CONFIG_SENSOR_SAMPLE_PERIOD_MS=250
CONFIG_SENSOR_POST_INTERVAL_SEC=2
# Calibration adjusted so 600mV -> 60 points with 5mV per point.
CONFIG_SENSOR_CLEAN_AIR_MV=300
CONFIG_SENSOR_DENSE_AIR_MV=700
CONFIG_SENSOR_SCORE_MAX=120
CONFIG_SENSOR_OUTPUT_INVERTED=n
CONFIG_SENSOR_WARNING_THRESHOLD=50
CONFIG_SENSOR_ALARM_THRESHOLD=85
CONFIG_I2S_BCLK_GPIO=5
CONFIG_I2S_WS_GPIO=4
CONFIG_I2S_DOUT_GPIO=18
CONFIG_I2S_SUPPRESS_DEPRECATE_WARN=y
CONFIG_ALARM_TONE_WARNING_HZ=760
CONFIG_ALARM_TONE_ALARM_HZ=980
CONFIG_ALARM_WARNING_BEEP_MS=170
CONFIG_ALARM_ALARM_BEEP_MS=260
CONFIG_ALARM_SOUND_ENABLED=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
