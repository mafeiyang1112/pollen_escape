page {
  background-color: #f5f7fa;
}

.leaderboard-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

/* ===== 头部样式 ===== */
.board-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding-bottom: 20rpx;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.2);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  height: 50rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.35);
}

.header-title {
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  flex: 1;
}

.header-spacer {
  width: 40rpx;
}

/* ===== 个人成绩卡片 ===== */
.my-score-card {
  margin: 16rpx 12rpx 0;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.my-score-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.my-score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.score-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

/* ===== 排行榜列表 ===== */
.leaderboard-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
  width: 100%;
}

.leaderboard-container {
  padding: 0 12rpx;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  margin: 12rpx 0;
  padding: 16rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.leaderboard-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

/* 排名徽章 */
.rank-section {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8eaf6 0%, #f3e5f5 100%);
  color: #666;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.rank-badge.rank-top1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  color: #333;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.3), inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
}

.rank-badge.rank-top2 {
  background: linear-gradient(135deg, #e8e8e8 0%, #f5f5f5 100%);
  color: #333;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.3), inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
}

.rank-badge.rank-top3 {
  background: linear-gradient(135deg, #cd7f32 0%, #da9d5f 100%);
  color: white;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.3), inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
}

/* 用户信息 */
.user-section {
  flex: 1;
  min-width: 0;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
  border: 2rpx solid #e0e0e0;
  object-fit: cover;
}

.user-name-wrap {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-stats {
  font-size: 18rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分数显示 */
.score-section {
  margin-left: 20rpx;
  text-align: right;
  flex-shrink: 0;
}

.total-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  line-height: 1;
}

.score-unit {
  font-size: 16rpx;
  color: #666;
  margin-top: 4rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  background: white;
  animation: fadeIn 0.3s ease;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 20rpx;
  color: #999;
}

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  background: white;
  z-index: 100;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 20rpx;
  color: #999;
  font-weight: 500;
}

/* ===== 错误状态 ===== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  background: white;
  animation: fadeIn 0.3s ease;
}

.error-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
  opacity: 0.7;
}

.error-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
  padding: 0 40rpx;
}

.retry-btn {
  padding: 12rpx 32rpx;
  font-size: 20rpx;
  color: white;
  background: #667eea;
  border: none;
  border-radius: 8rpx;
}

.retry-btn:active {
  background: #5568d3;
  opacity: 0.9;
}

/* ===== 动画 ===== */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
