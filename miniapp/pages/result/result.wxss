.result-page {
  transition: background 220ms ease;
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

/* 背景渐变色，参照第二张图片 */
.result-page.status-high {
  background: linear-gradient(135deg, #ff6b6b, #ffd93d);
}

.result-page.status-mid {
  background: linear-gradient(135deg, #ff9a9e, #fad0c4);
}

.result-page.status-low {
  background: linear-gradient(135deg, #a8edea, #fed6e3);
}

.result-page.status-unknown {
  background: linear-gradient(135deg, #f6d365, #fda085);
}

/* 背景装饰 */
.background-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.petal {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50% 0 50% 0;
  opacity: 0.1;
  animation: float 15s infinite ease-in-out;
}

.petal-1 {
  top: 10%;
  left: 10%;
  background: rgba(255, 182, 193, 0.8);
  animation-delay: 0s;
}

.petal-2 {
  top: 30%;
  right: 15%;
  background: rgba(173, 216, 230, 0.8);
  animation-delay: 3s;
}

.petal-3 {
  bottom: 20%;
  left: 20%;
  background: rgba(221, 160, 221, 0.8);
  animation-delay: 6s;
}

.petal-4 {
  bottom: 40%;
  right: 25%;
  background: rgba(255, 228, 196, 0.8);
  animation-delay: 9s;
}

/* 闪光点 */
.sparkle {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  animation: sparkle 3s infinite ease-in-out;
}

.sparkle-1 {
  top: 20%;
  right: 30%;
  animation-delay: 0s;
}

.sparkle-2 {
  bottom: 30%;
  left: 25%;
  animation-delay: 1s;
}

.sparkle-3 {
  top: 60%;
  right: 20%;
  animation-delay: 2s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(180deg);
  }
}

@keyframes sparkle {
  0%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.5);
  }
}

/* 页面标题 */
.page-title {
  text-align: center;
  margin-bottom: 40rpx;
  z-index: 1;
}

.main-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 卡通形象 */
.cartoon-character {
  position: relative;
  margin-bottom: 40rpx;
  z-index: 1;
}

.character {
  font-size: 64rpx;
  animation: bounce 2s infinite ease-in-out;
}

.flower {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  font-size: 32rpx;
  animation: spin 3s infinite linear;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 毛玻璃效果 */
.glass-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  max-width: 600rpx;
  z-index: 1;
}

.glass-card:hover {
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  transform: translateY(-2rpx);
}

/* 战绩卡样式 */
.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 248, 220, 0.8));
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
}

.player-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 18rpx;
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.92);
  background: #f3f4f6;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.14);
}

.player-nickname {
  margin-top: 12rpx;
  max-width: 420rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #334155;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.score-label {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.final-score {
  font-size: 120rpx;
  line-height: 1.1;
  font-weight: 700;
  background: linear-gradient(135deg, #ffd700, #ffed4e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 4rpx 8rpx rgba(255, 215, 0, 0.3);
  margin-bottom: 24rpx;
}

.rank-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.1), rgba(255, 215, 0, 0.05));
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.trophy-icon {
  font-size: 32rpx;
  animation: pulse 2s infinite ease-in-out;
}

.rank-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.chart-card {
  overflow: hidden;
  padding: 24rpx;
}

canvas {
  margin-top: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
  padding: 24rpx;
}

.cta-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
  border: none;
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.cta-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.4);
}

.play-again {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: color 0.3s ease;
}

.play-again:hover {
  color: #ff6b6b;
}

.board-card {
  padding: 24rpx;
}

.board-row {
  margin-top: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.board-row:hover {
  background: rgba(255, 255, 255, 0.5);
  padding-left: 12rpx;
  border-radius: 8rpx;
}

.board-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #eef2f7;
  color: #4b5563;
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.3s ease;
}

.rank-badge.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffed4e);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.3);
}

.rank-badge.rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #e8e8e8);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.3);
}

.rank-badge.rank-3 {
  background: linear-gradient(135deg, #cd7f32, #ffc107);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.3);
}

.board-name {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 500;
}

.board-score {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  text-align: center;
}

.muted {
  color: #9ca3af;
  font-size: 24rpx;
}

.error {
  color: #ef4444;
  font-size: 24rpx;
  text-align: center;
  margin-top: 20rpx;
  z-index: 1;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .final-score {
    font-size: 100rpx;
  }
  
  .score-card {
    padding: 36rpx 20rpx;
  }
}
