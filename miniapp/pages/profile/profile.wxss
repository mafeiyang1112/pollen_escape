.profile-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
}

.hero-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.hero-visual {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 30rpx;
}

.spore {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  animation: float 6s ease-in-out infinite;
}

.spore-1 {
  width: 80rpx;
  height: 80rpx;
  top: 20rpx;
  left: 20rpx;
  animation-delay: 0s;
}

.spore-2 {
  width: 60rpx;
  height: 60rpx;
  top: 60rpx;
  right: 10rpx;
  animation-delay: 2s;
}

.spore-3 {
  width: 40rpx;
  height: 40rpx;
  bottom: 30rpx;
  left: 60rpx;
  animation-delay: 4s;
}

.hero-runner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  background: rgba(0, 0, 0, 0.2);
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.profile-box {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.welcome-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 10rpx;
}

.desc-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  width: 160rpx !important;   /* 寮哄埗閿佸畾瀹藉害 */
  height: 160rpx !important;  /* 寮哄埗閿佸畾楂樺害 */
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  padding: 0 !important;      /* 褰诲簳娓呴櫎寰俊鎸夐挳榛樿鍐呰竟璺?*/
  margin: 0 auto 20rpx;
  display: flex;              /* 璁╁唴閮ㄧ殑 image 瀹岀編灞呬腑 */
  align-items: center;
  justify-content: center;
  flex-shrink: 0;             /* 缁堟瀬闃叉尋鍘嬪睘鎬?*/
}

.avatar-wrapper::after {
  border: none !important;
}

.avatar {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-tip {
  font-size: 24rpx;
  color: #666;
}

.nickname-section {
  margin-bottom: 40rpx;
}

.nickname-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.error-text {
  color: #ff4d4f;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  padding: 24rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
}

.primary-btn:hover {
  opacity: 0.9;
  transform: translateY(-2rpx);
}

.secondary-btn {
  background: #f0f0f0;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.secondary-btn:hover {
  background: #e0e0e0;
}

.agreement {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}
