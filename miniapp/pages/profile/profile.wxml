<view class="profile-page">
  <view class="hero-section">
    <view class="hero-visual">
      <view class="spore spore-1"></view>
      <view class="spore spore-2"></view>
      <view class="spore spore-3"></view>
      <view class="hero-runner">RUN</view>
    </view>
    <view class="app-name">花粉逃离大赛</view>
    <view class="app-slogan">远离高浓度，跑得越快分越高</view>
  </view>

  <view class="profile-box">
    <view class="welcome-text">完善个人信息</view>
    <view class="desc-text">请设置您的头像和昵称</view>

    <view class="avatar-section">
      <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          class="avatar"
          src="{{avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}"
          mode="aspectFill"
        ></image>
      </button>
      <view class="avatar-tip">点击选择头像</view>
    </view>

    <view class="nickname-section">
      <input
        type="nickname"
        class="nickname-input"
        placeholder="请输入昵称"
        bindblur="onNicknameBlur"
        value="{{nickname}}"
      />
    </view>

    <view wx:if="{{lastError}}" class="error-text">{{lastError}}</view>

    <view class="action-buttons">
      <button
        class="action-btn primary-btn"
        loading="{{loading}}"
        bindtap="onComplete"
        disabled="{{loading}}"
      >
        完成
      </button>
      <button
        class="action-btn secondary-btn"
        bindtap="onSkip"
        disabled="{{loading}}"
      >
        跳过
      </button>
    </view>

    <view class="agreement">登录即表示同意《用户服务协议》与《隐私政策》</view>
  </view>
</view>
