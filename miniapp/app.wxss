page {
  background: #f7f9fb;
  color: #1f2937;
  font-size: 28rpx;
}

.page-wrap {
  min-height: 100%;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.06);
}

.section-title {
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2937;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label {
  color: #6b7280;
  font-size: 26rpx;
}

.value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}

.big-number {
  font-size: 88rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2937;
}

.cta-btn {
  width: 100%;
  height: 96rpx;
  line-height: 1.1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  border-radius: 48rpx;
  border: 0;
  background: #3ccf91 !important;
  color: #ffffff !important;
  font-size: 34rpx;
  font-weight: 700;
}

.cta-btn::after {
  border: 0;
}

.breathe {
  animation: breathe 2.1s ease-in-out infinite;
}

.mini-btn {
  border-radius: 999rpx;
  border: 1rpx solid #d9dee7;
  background: #ffffff;
  color: #1f2937;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  border-radius: 24rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-high {
  background: rgba(255, 90, 95, 0.14);
  color: #ff5a5f;
}

.status-mid {
  background: rgba(255, 159, 67, 0.16);
  color: #ff9f43;
}

.status-low {
  background: rgba(60, 207, 145, 0.18);
  color: #3ccf91;
}

.status-unknown {
  background: rgba(107, 114, 128, 0.16);
  color: #6b7280;
}

.link-text {
  color: #4b5563;
  font-size: 24rpx;
}

.error {
  margin-top: 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 90, 95, 0.28);
  background: rgba(255, 90, 95, 0.08);
  color: #c53d41;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
}

@keyframes breathe {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes score-pop {
  0% {
    transform: scale(0.88);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes flash {
  0% {
    transform: scale(1);
    opacity: 0.7;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 0.86;
  }
}
